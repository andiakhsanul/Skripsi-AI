# Threshold selection: minimum recall Indikasi yang harus dipertahankan.
# 0.80 dipilih sebagai trade-off antara recall (meminimalkan false negative)
# dan accuracy. Dataset 902 baris dengan ~21% conflict rate menyulitkan
# pencapaian recall 0.85 dan accuracy >0.80 sekaligus.
MIN_INDIKASI_RECALL=0.80
