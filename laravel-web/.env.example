# Environment khusus Laravel Web
APP_NAME=SPK-KIPK-SaaS
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=spk_kipk_db
DB_USERNAME=postgres
DB_PASSWORD=postgres
CACHE_STORE=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync

FLASK_API_URL=http://flask-api:5000/api/predict
FLASK_RETRAIN_URL=http://flask-api:5000/api/retrain
FLASK_INTERNAL_TOKEN=spk_internal_dev_token
RULE_RECOMMENDATION_THRESHOLD=0.6

GOOGLE_OAUTH_CLIENT_FILE=storage/app/google/oauth-client.json
GOOGLE_OAUTH_TOKEN_FILE=storage/app/google/oauth-token.json
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_DRIVE_APP_NAME="SPK-KIPK Laravel"
